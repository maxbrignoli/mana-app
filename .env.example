# ============================================================
# Variabili d'ambiente del backend Vercel (api/)
# ============================================================
# In locale: copiare questo file in .env e riempire i valori reali.
# Su Vercel: configurare via UI o `vercel env`. NON committare mai .env.

# --- AI provider ---
# Provider attivo: 'openai' (default) | 'anthropic'
AI_PROVIDER=openai
# Modello specifico. Per OpenAI: gpt-5.4-mini | gpt-5.4-nano | gpt-5.4
# Per Anthropic: claude-haiku-4-5 | claude-sonnet-4-6 | claude-opus-4-5
AI_MODEL=gpt-5.4-mini
# API key del provider scelto. Solo una delle due e' obbligatoria.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
# Service role key (SEGRETA, mai esporre al client mobile)
SUPABASE_SERVICE_ROLE_KEY=

# --- Runtime ---
# Livello log minimo: debug | info | warn | error
LOG_LEVEL=info

# ============================================================
# Variabili lato client Flutter (legge da .env nell'app)
# ============================================================

# Stesso URL Supabase (anche il client lo usa)
# SUPABASE_URL=...

# Chiave pubblica (anon/publishable), sicura nel client mobile
SUPABASE_ANON_KEY=
